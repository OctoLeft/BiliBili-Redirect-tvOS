name: "{{@package 'displayName'}}"
desc: |-
  {{#each (split (@package 'description') "\n")}}
  {{{this}}}
  {{/each}}
openUrl: "{{@package 'openUrl'}}"
author: |-
  {{#each (@package 'contributors')}}
  {{this}}
  {{/each}}
homepage: "{{@package 'homepage'}}"
icon: "{{@package 'icon'}}"
category: "{{@package 'organizationName'}}"
date: "{{now "yyyy-MM-dd HH:mm:ss"}}"
version: "{{@package 'version'}}"

http:
  force-http-engine:
    - "*:4480"
    - "*:8000"
    - "*:9102"
  mitm:
    - "*.mcdn.bilivideo.cn"
    - "*.mcdn.bilivideo.cn:4483"
    - "*.mcdn.bilivideo.cn:8082"
    - "upos-sz-mirror*bstar1.bilivideo.com"
    - "upos-*-mirrorakam.akamaized.net"
    - "app.bilibili.com"
    - "app.biliapi.net"
    - "api.bilibili.com"
    - "api.biliapi.net"
    - "grpc.biliapi.net"
  script:
    - match: ^https?:\/\/(grpc\.biliapi\.net|app\.biliapi\.net|app\.bilibili\.com)\/bilibili\.app\.playerunite\.v1\.Player\/PlayViewUnite$
      name: "📺 BiliBili.Redirect.response"
      type: response
      require-body: true
      binary-mode: true
      argument:
    - match: ^https?:\/\/api\.bili(bili\.com|api\.net)\/(x\/player\/(wbi\/)?playurl|pgc\/player\/(api|web)\/playurl(\/html5)?|pgc\/player\/web\/v2\/playurl)\?
      name: "📺 BiliBili.Redirect.response"
      type: response
      require-body: true
      argument:
    - match: ^https?:\/\/.+\.bilivideo\.com\/upgcxcode\/
      name: "📺 BiliBili.Redirect.request"
      type: request
    - match: ^https?:\/\/[adbcefxy0-9]+\.mcdn\.bilivideo\.cn(:(8000|8082))?\/v1\/resource\/
      name: "📺 BiliBili.Redirect.request"
      type: request
      argument:
    - match: ^https?:\/\/[adbcefxy0-9]+\.mcdn\.bilivideo\.cn(:(4483|9102))?\/upgcxcode\/
      name: "📺 BiliBili.Redirect.request"
      type: request
      argument:
    - match: ^https?:\/\/(.+):4480\/upgcxcode\/
      name: "📺 BiliBili.Redirect.request"
      type: request
      argument:
    - match: ^https?:\/\/upos-(hz|bstar1)-mirrorakam\.akamaized\.net/upgcxcode\/
      name: "📺 BiliBili.Redirect.request"
      type: request
      argument:
script-providers:
  "📺 BiliBili.Redirect.response":
    url: https://github.com/OctoLeft/BiliBili-Redirect-tvOS/releases/download/v{{@package 'version'}}/response.bundle.js
    interval: 86400
  "📺 BiliBili.Redirect.request":
    url: https://github.com/OctoLeft/BiliBili-Redirect-tvOS/releases/download/v{{@package 'version'}}/request.bundle.js
    interval: 86400
